# Copy this to .env and fill in your values
# In Vercel dashboard: add BOTH of these as Environment Variables for the frontend project

# Local development
# VITE_API_URL=http://localhost:5000

# Production (your deployed backend URL on Vercel)
# VITE_API_URL=https://your-backend-name.vercel.app

# Razorpay public key (get from razorpay.com dashboard — use test key for testing)
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
